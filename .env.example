# 复制本文件为 .env 或 .env.local 后填写（.env.local 更适合放 Key，勿提交仓库）
#
# 仅当 VITE_LLM_API_BASE 与 VITE_LLM_API_KEY 都非空时，才会请求真实接口；
# 否则继续使用内置 Mock。
#
# 对接 OpenAI 或兼容 OpenAI Chat Completions 的网关时使用：
VITE_LLM_API_BASE=https://api.openai.com/v1
VITE_LLM_API_KEY=sk-your-key-here
VITE_LLM_MODEL=gpt-4o-mini

# 设为 0 时：不自动打开「预览」；默认会自动切到「预览」渲染 HTML
# VITE_AUTO_PREVIEW=0

# 若 cdn.tailwindcss.com 在你网络下无法加载，可改为可访问的地址（需为 Play CDN 同类脚本）
# VITE_TAILWIND_CDN_URL=https://cdn.tailwindcss.com
